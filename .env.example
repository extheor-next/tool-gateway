# Tool Gateway runtime
# Runtime listen port inside the app/container
PORT=5001
# Docker Compose host port (compose only; container still listens on PORT)
TOOL_GATEWAY_HOST_PORT=6011
LOG_LEVEL=INFO

# Admin authentication
TOOL_GATEWAY_ADMIN_KEY=change-me

# Config loading (choose one)
# 1) file-based config
TOOL_GATEWAY_CONFIG_PATH=/app/config.json
# 2) inline JSON or Base64 JSON
# TOOL_GATEWAY_CONFIG_JSON=
# 3) legacy compatibility alias
# CONFIG_JSON=

# External OpenAI-compatible upstream model
# You can also set these in config.json under external_ai.
EXTERNAL_AI_BASE_URL=https://api.openai.com/v1
EXTERNAL_AI_API_KEY=sk-your-upstream-key
EXTERNAL_AI_MODEL=gpt-4o-mini

# Optional: static admin assets path
# TOOL_GATEWAY_STATIC_ADMIN_DIR=/app/static/admin
